# Copy this file to .env.local and fill in your Supabase project's values.
# See supabase/SETUP.md for the full walkthrough.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Non-secret salt mixed into each 4-digit PIN to satisfy Supabase Auth's
# 6-character password minimum. Change this to your own value before going
# live — anyone who knows it (and a PIN) can derive the Auth password.
VITE_APP_PIN_SALT=mekk-olen-
